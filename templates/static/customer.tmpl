{{template "top" .}}
    <title>{{.Title}}</title>
    <style>
        @keyframes spin-slow {
            to {transform: rotate(360deg);}
        }
        .animate-spin-slow{
            animation: spin-slow 5s linear infinite;
        }
    </style>
</head>
<body class="bg-gradient-to-br from-amber-50 via-orange-50 to-rose-50 min-h-screen">
    <div class="flex flex-col items-center p-6 md:p-8 ">
        <img src="/static/pizza.svg" alt="Pizza loading..." class="w-48 h-28 mb-10 animate-spin-slow drop-shadow-lg">
        <div id="statusContainer" class="bg-white/80 backdrop-blur-sm p-8 md:pd-10 rounded-3xl shadow-2xl borer border-white/20 max-w-3xl w-full "></div>
        <h1 class="text-2xl font-bold mb-4">
            Track Your Pizza Order!
        </h1>
        <p class="text-lg mb-2">Order ID:</p>
        <p class="text-xl font-bold mb-4">
            {{.Order.ID}}
        </p>
    </div>
{{template "bottom" .}}