{{template "top" .}}
    <title>Admin Dashboard - Pizza Tracker</title>
</head>
<body class="bg-gradient-to-br from-amber-50 via-orange-50 to-rose-50 min-h-screen">
    <div class="container mx-auto px-4 md:py-12">
        <div class="max-w-[95%] mx-auto ">
            <div class="fle justify-between items-center mb-8">
                
            </div>
        </div>
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-4xl md:text-5xl fonr-bold text-gray-900 mb-2 tracking-tight">
                Pizza Tracker Admin
                </h1>
                <p class="text-gray-600 text-lg">Track and manage all your pizza orders.</p>
            </div>
            <div class="flex items-center gap-4">
                <span class="text-gray-700 font-medium">
                    Welcome, {{.Username}}
                </span>
                <form action="/logout" method="POST">
                    <button type="submit" class="px-5 py-2.5 bg-red-500 text-white text-sm rounded-xl hover:bg-red-600 active:scale-95 transition-all shadow-sm">Logout</button>
                </form>
            </div>
        </div>
        <div>
            
        </div>
    </div>
{{template "bottom" .}}